# ================================================================
# Environment Configuration — Water Potability MLOps
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ================================================================

# --- MLflow ---
# Local:   http://localhost:5001
# Cloud:   (retrieve from Azure ML Workspace)
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=water-potability-mlops

# --- Model Registry ---
MODEL_NAME=water_potability_model
MODEL_STAGE_OR_ALIAS=Production

# --- Azure Blob Storage ---
# Provide EITHER connection string OR account name
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_STORAGE_ACCOUNT=waterpotabilitystorage
AZURE_STORAGE_CONTAINER=datasets

# --- Dataset ---
# Override dataset version (auto-generated if empty)
DATASET_VERSION=
